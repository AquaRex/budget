# Copy this file to .env.local and fill in the anon key.
# These are NEXT_PUBLIC_* so they are inlined into the static build (safe — the
# anon key is meant to be public; your data is protected by Supabase Auth + MFA + RLS).

NEXT_PUBLIC_SUPABASE_URL=https://ecqrqrlupxgaulhpuclf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Pre-filled on the login screen (you can still type any account's email).
NEXT_PUBLIC_AUTH_EMAIL=hetland.th@gmail.com

# Demo account (fake data, exempt from 2FA — see migration 0014). Keep the email
# in sync with that migration. Setting the password enables one-click "View demo";
# leave it blank to just pre-fill the demo email on the login screen.
NEXT_PUBLIC_DEMO_EMAIL=demo@demo.com
NEXT_PUBLIC_DEMO_PASSWORD=

# Set automatically by `pnpm deploy` (=/budget). Leave blank for local dev.
NEXT_PUBLIC_BASE_PATH=
